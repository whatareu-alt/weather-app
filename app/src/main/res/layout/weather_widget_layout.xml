<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:padding="16dp">

    <TextView
        android:id="@+id/widget_city"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentStart="true"
        android:layout_alignParentTop="true"
        android:layout_toStartOf="@id/widget_online_status"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:text="@string/widget_default_city"
        android:ellipsize="end"
        android:singleLine="true"
        android:maxLines="1" />

    <TextView
        android:id="@+id/widget_online_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_alignParentTop="true"
        android:textColor="#FF5555"
        android:textSize="12sp"
        android:textStyle="bold"
        android:text="" />

    <TextView
        android:id="@+id/widget_description"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/widget_city"
        android:layout_alignParentStart="true"
        android:layout_marginTop="4dp"
        android:textColor="#B0C4DE"
        android:textSize="13sp"
        android:text="@string/widget_loading"
        android:ellipsize="end"
        android:singleLine="true"
        android:maxLines="1" />

    <TextView
        android:id="@+id/widget_temp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:textColor="#FFFFFF"
        android:textSize="36sp"
        android:textStyle="bold"
        android:text="@string/widget_temp_placeholder" />

</RelativeLayout>
