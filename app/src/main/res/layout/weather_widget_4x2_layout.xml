<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container_4x2"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="14dp">

    <!-- Top row: city + temp -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/widget_city_4x2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:ellipsize="end"
                android:singleLine="true"
                android:text="Mumbai" />

            <TextView
                android:id="@+id/widget_desc_4x2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#B0C4DE"
                android:textSize="12sp"
                android:ellipsize="end"
                android:singleLine="true"
                android:text="Partly cloudy" />

            <TextView
                android:id="@+id/widget_hl_4x2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#90A8C4"
                android:textSize="11sp"
                android:text="H: 34° · L: 26°" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <TextView
                android:id="@+id/widget_temp_4x2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="42sp"
                android:textStyle="bold"
                android:text="31°" />

            <TextView
                android:id="@+id/widget_uv_4x2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFD580"
                android:textSize="11sp"
                android:gravity="center"
                android:text="UV 8 · High" />

        </LinearLayout>

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginVertical="6dp"
        android:background="#40FFFFFF" />

    <!-- Bottom row: 5-hour strip -->
    <LinearLayout
        android:id="@+id/widget_hourly_strip"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Hour slots filled programmatically via RemoteViews child slots -->
        <LinearLayout
            android:id="@+id/widget_hour_0"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView android:id="@+id/widget_hour_0_time"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="#90A8C4" android:textSize="10sp" android:text="Now"/>
            <TextView android:id="@+id/widget_hour_0_icon"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="#FFFFFF" android:textSize="16sp" android:text="⛅"/>
            <TextView android:id="@+id/widget_hour_0_temp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="#FFFFFF" android:textSize="12sp" android:textStyle="bold" android:text="31°"/>
            <TextView android:id="@+id/widget_hour_0_precip"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="#6EA8FE" android:textSize="9sp" android:text="5%"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/widget_hour_1"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView android:id="@+id/widget_hour_1_time"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="#90A8C4" android:textSize="10sp" android:text="1PM"/>
            <TextView android:id="@+id/widget_hour_1_icon"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="#FFFFFF" android:textSize="16sp" android:text="☀"/>
            <TextView android:id="@+id/widget_hour_1_temp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="#FFFFFF" android:textSize="12sp" android:textStyle="bold" android:text="33°"/>
            <TextView android:id="@+id/widget_hour_1_precip"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="#6EA8FE" android:textSize="9sp" android:text="2%"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/widget_hour_2"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView android:id="@+id/widget_hour_2_time"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="#90A8C4" android:textSize="10sp" android:text="2PM"/>
            <TextView android:id="@+id/widget_hour_2_icon"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="#FFFFFF" android:textSize="16sp" android:text="🌦"/>
            <TextView android:id="@+id/widget_hour_2_temp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="#FFFFFF" android:textSize="12sp" android:textStyle="bold" android:text="34°"/>
            <TextView android:id="@+id/widget_hour_2_precip"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="#6EA8FE" android:textSize="9sp" android:text="18%"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/widget_hour_3"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView android:id="@+id/widget_hour_3_time"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="#90A8C4" android:textSize="10sp" android:text="3PM"/>
            <TextView android:id="@+id/widget_hour_3_icon"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="#FFFFFF" android:textSize="16sp" android:text="🌧"/>
            <TextView android:id="@+id/widget_hour_3_temp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="#FFFFFF" android:textSize="12sp" android:textStyle="bold" android:text="31°"/>
            <TextView android:id="@+id/widget_hour_3_precip"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="#6EA8FE" android:textSize="9sp" android:text="62%"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/widget_hour_4"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView android:id="@+id/widget_hour_4_time"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="#90A8C4" android:textSize="10sp" android:text="4PM"/>
            <TextView android:id="@+id/widget_hour_4_icon"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="#FFFFFF" android:textSize="16sp" android:text="🌧"/>
            <TextView android:id="@+id/widget_hour_4_temp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="#FFFFFF" android:textSize="12sp" android:textStyle="bold" android:text="29°"/>
            <TextView android:id="@+id/widget_hour_4_precip"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="#6EA8FE" android:textSize="9sp" android:text="74%"/>
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
